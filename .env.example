# Copy to .env and fill in. NEVER commit your real .env.

# OpenAI (Realtime API for the patient voice + bug analysis)
OPENAI_API_KEY=sk-...
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=alloy
ANALYZE_MODEL=gpt-4o

# Twilio (places the calls + records them)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1XXXXXXXXXX        # your single Twilio caller number (use one for all calls)

# The assessment line you are testing. Do not change.
TARGET_NUMBER=+18054398008

# Public host where THIS server is reachable (ngrok during dev), no scheme.
# e.g. PUBLIC_HOST=abc123.ngrok-free.app
PUBLIC_HOST=your-ngrok-host.ngrok-free.app

# Safety cap on call length (seconds)
MAX_CALL_SECONDS=240
